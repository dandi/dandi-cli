\nfrom getpass import getpass\ntoken = getpass(\"Enter API key: \")\n\napi = DandiAPIClient(token=token)\nds = api.get_dandiset(\u003cid\u003e)\nasset = ds.get_asset(\u003cid\u003e)\n\nasset.base_download_url\nres = asset.client.session.head(asset.base_download_url)\ns3_url = res.headers['Location']\n\nimport fsspec\nimport pynwb\nimport h5py\nfrom fsspec.implementations.cached import CachingFileSystem\n\nfs = CachingFileSystem(\n    fs=fsspec.filesystem(\"http\"),\n    cache_storage=\"nwb-cache\",  # Local folder for the cache\n)\nwith fs.open(s3_url, \"rb\") as f:\n    with h5py.File(f) as file:\n        with pynwb.NWBHDF5IO(file=file, load_namespaces=True) as io:\n            nwbfile = io.read()\n            print(nwbfile.acquisition)\n```","files":null},{"type":2,"timestamp":1665453862,"nonce":"7CE8agPhTTzzSr3itVAvW+P+IIM=","metadata":{"github-id":"RTE_lADODBZtRc5TrcLezwAAAAHCgSCx"},"title":"add support for signed url location to access embargoed data with fsspec","was":"add support for signed url location to access embargoed data with fsspec"}]}